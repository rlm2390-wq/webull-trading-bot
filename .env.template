# Copy this to .env and fill in your values.  Never commit .env to git.

DATABASE_URL=postgresql://trading_user:changeme@localhost:5432/trading_engine

WEBULL_USERNAME=your@email.com
WEBULL_PASSWORD=yourpassword
WEBULL_DEVICE_ID=your_device_id_hex
WEBULL_TRADE_PIN=your6digitpin
WEBULL_MFA_CODE=           # optional TOTP base32 secret

LOG_LEVEL=INFO
LOG_DIR=logs
TZ=America/New_York

# Set to "true" for paper-trading / testing (no real orders placed)
DRY_RUN=false

ENVIRONMENT=production
